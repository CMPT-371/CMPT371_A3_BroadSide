# ============================================================================
# BroadSide — .gitignore
# ============================================================================
# Tailored for a Python 3.10+ Tkinter + Pillow project on macOS/Windows/Linux.
# Organized by category. Each section explains WHY the entries exist.
# ============================================================================


# ── Python byte-compiled / optimized files ─────────────────────────────────
# Generated automatically when Python imports a module. Never committed
# because they are platform- and version-specific.
__pycache__/
*.py[cod]
*$py.class


# ── C extensions ───────────────────────────────────────────────────────────
# Compiled shared objects from C extension modules (e.g., Pillow's internal
# C accelerators). Built locally during `pip install`.
*.so
*.pyd


# ── Virtual environments ──────────────────────────────────────────────────
# The venv directory contains all installed packages and the Python
# interpreter symlink. Each team member creates their own from
# `python -m venv venv` + `pip install -r requirements.txt`.
venv/
.venv/
env/
ENV/
env.bak/
venv.bak/


# ── Distribution / packaging ──────────────────────────────────────────────
# Artifacts from `pip install -e .`, `python setup.py build`, or
# `python -m build`. Not applicable to this project but included
# defensively in case a team member experiments.
build/
dist/
*.egg-info/
*.egg
.Python
MANIFEST


# ── pip ────────────────────────────────────────────────────────────────────
# Installer logs produced by pip on failure.
pip-log.txt
pip-delete-this-directory.txt


# ── Testing / coverage ────────────────────────────────────────────────────
# Output from pytest, coverage.py, tox, and nox.
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache/
.pytest_cache/
nosetests.xml
coverage.xml
*.cover
*.py.cover


# ── Type checking ─────────────────────────────────────────────────────────
# Cache directories from mypy, pyright, pytype, and pyre.
.mypy_cache/
.dmypy.json
dmypy.json
.pyright/
.pytype/
.pyre/


# ── Linting / formatting ─────────────────────────────────────────────────
# Cache from ruff (fast Python linter/formatter).
.ruff_cache/


# ── macOS ─────────────────────────────────────────────────────────────────
# .DS_Store: Finder metadata (folder view settings, icon positions).
# Created automatically in every directory Finder opens.
# ._* : Apple Double resource fork files created on non-HFS+ volumes.
.DS_Store
.DS_Store?
._*
.AppleDouble
.LSOverride
.Spotlight-V100
.Trashes

# macOS: Thumbnails cache
Icon?


# ── Windows ───────────────────────────────────────────────────────────────
# Thumbs.db: Windows Explorer thumbnail cache.
# desktop.ini: Folder customization metadata.
# ehthumbs.db: Media Center thumbnail cache.
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
desktop.ini

# Windows: Recycle Bin metadata
$RECYCLE.BIN/

# Windows: Shortcuts
*.lnk


# ── Linux ─────────────────────────────────────────────────────────────────
# Temporary files and backup files created by various editors.
*~
.fuse_hidden*
.nfs*


# ── IDE: Visual Studio Code ──────────────────────────────────────────────
# User-specific settings, debug configs, task runner configs, and
# extensions metadata. Each developer configures their own.
.vscode/


# ── IDE: JetBrains (PyCharm, IntelliJ) ───────────────────────────────────
# Project settings, run configurations, and local history.
.idea/


# ── IDE: Sublime Text ────────────────────────────────────────────────────
*.sublime-project
*.sublime-workspace


# ── AI coding assistants ──────────────────────────────────────────────────
# Claude Code: local session state and memory files.
.claude/

# Cursor: AI editor ignore/indexing config (user-specific).
.cursorignore
.cursorindexingignore

# Aider: AI pair programming session files.
.aider*


# ── Video demo working files ─────────────────────────────────────────────
# Raw screen recordings and editing project files used to produce the
# final demo video. Only the finished video (or a link) belongs in the repo.
# The demo/ directory itself IS tracked (for the final .mp4 or .gitkeep).
*.mov
*.avi
*.mkv
*.wmv
*.flv
*.webm

# Keep .mp4 files tracked — the final demo is delivered as .mp4.
# (No negation needed: .mp4 is not ignored by default.)


# ── Logs ──────────────────────────────────────────────────────────────────
# Runtime log files produced by the server's logging module.
*.log


# ── Environment / secrets ─────────────────────────────────────────────────
# Environment variable files that might contain sensitive configuration.
# Not used in this project, but included as a safety net.
.env
.env.*
!.env.example


# ── Miscellaneous ─────────────────────────────────────────────────────────
# Editor swap and backup files.
*.swp
*.swo
*.swn
*.bak
*.tmp
*.temp

# Archives (should not be committed).
*.zip
*.tar.gz
*.rar
*.7z
